{
  "servers": [
    { "_comment": "Strict orchestrator profile: minimal lanes, deterministic behavior." },
    { "_comment": "ChittyAgent-Tasks — enable once /mcp endpoint ships on tasks.chitty.cc." },
    {
      "id": "tasks",
      "name": "ChittyAgent Tasks",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://tasks.chitty.cc/mcp",
      "authTokenKey": "chittytasks",
      "lazy": true,
      "enabled": false
    },
    {
      "id": "chittyos",
      "name": "ChittyOS Ecosystem",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://mcp-portal.chitty.cc/mcp",
      "envHeaders": {
        "CF-Access-Client-Id": "CHITTY_CF_ACCESS_CLIENT_ID",
        "CF-Access-Client-Secret": "CHITTY_CF_ACCESS_CLIENT_SECRET"
      },
      "authTokenKey": "chittymcp",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "cloudflare",
      "name": "Cloudflare Platform",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://mcp.cloudflare.com/mcp",
      "authTokenKey": "cloudflare-mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "evidence",
      "name": "Evidence Search",
      "type": "remote",
      "access": "read",
      "category": "search",
      "endpoint": "https://autorag.mcp.cloudflare.com/mcp",
      "authTokenKey": "chittyevidence-search",
      "lazy": true,
      "enabled": false
    }
  ]
}
