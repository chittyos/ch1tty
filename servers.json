{
  "servers": [

    {"_comment": "── ecosystem: Read and Write ChittyOS Infrastructure ───────"},

    {
      "id": "remote",
      "name": "Read and Write ChittyOS",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "/bin/sh",
      "args": ["-lc", "TOKEN=\"$(/Users/nb/.local/bin/chitty-mcp-token chittymcp 2>/dev/null || true)\"; if [ -n \"$TOKEN\" ]; then export MCP_AUTH_HEADER=\"Bearer $TOKEN\"; fi; exec npx -y mcp-remote https://mcp.chitty.cc/mcp"],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "cloudflare",
      "name": "Read and Write Cloudflare",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://builds.mcp.cloudflare.com/mcp",
      "authTokenKey": "cloudflare-mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "neon",
      "name": "Read and Write Neon Database",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "/bin/sh",
      "args": ["-lc", "exec npx -y @neondatabase/mcp-server-neon start \"$NEON_API_KEY\""],
      "env": {
        "NEON_API_KEY": "op://ChittyOS-Integrations/neon/api_key"
      },
      "lazy": true,
      "enabled": true
    },

    {"_comment": "── code: Read and Write Source Code ───────────────────────"},

    {
      "id": "serena",
      "name": "Read and Write Source Code",
      "type": "local",
      "access": "readwrite",
      "category": "code",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server"],
      "lazy": true,
      "enabled": true
    },

    {
      "id": "quality",
      "name": "Read and Write Quality Metrics",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "node",
      "args": ["/Users/nb/.config/claude/mcp-servers/chitty-quality/build/index.js"],
      "env": {
        "NEON_DATABASE_URL": "op://Private/Neon/database_url"
      },
      "lazy": true,
      "enabled": true
    },

    {"_comment": "── search: Search Evidence ────────────────────────────────"},

    {
      "id": "evidence",
      "name": "Search Evidence Documents",
      "type": "remote",
      "access": "read",
      "category": "search",
      "endpoint": "https://autorag.mcp.cloudflare.com/mcp",
      "authTokenKey": "chittyevidence-search",
      "lazy": true,
      "enabled": true
    },

    {"_comment": "── reasoning: Read-only Reasoning ────────────────────────"},

    {
      "id": "thinking",
      "name": "Sequential Thinking",
      "type": "local",
      "access": "read",
      "category": "reasoning",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "lazy": true,
      "enabled": true
    },

    {"_comment": "── desktop: Read and Write Local Machine ─────────────────"},

    {
      "id": "fs",
      "name": "Read and Write Filesystem",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/nb/.claude/projects", "/Users/nb/Documents", "/Users/nb/Desktop"],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "desktop",
      "name": "Control your Mac",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": ["-y", "@wonderwhy-er/desktop-commander@latest"],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "chrome",
      "name": "Control Chrome",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "node",
      "args": ["/Users/nb/Library/Application Support/Claude/Claude Extensions/ant.dir.ant.anthropic.chrome-control/server/index.js"],
      "lazy": true,
      "enabled": true
    },

    {
      "id": "playwright",
      "name": "Control Browser Automation",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "lazy": true,
      "enabled": true
    },

    {"_comment": "── documents: Fill and Analyze Documents ──────────────────"},

    {
      "id": "pdf",
      "name": "Fill and Analyze PDFs",
      "type": "local",
      "access": "write",
      "category": "documents",
      "command": "node",
      "args": ["/Users/nb/Library/Application Support/Claude/Claude Extensions/ant.dir.gh.silverstein.pdf-filler-simple/server/index.js"],
      "lazy": true,
      "enabled": true
    },

    {"_comment": "── communication: Read and Send Messages ──────────────────"},

    {
      "id": "chittymac",
      "name": "Read and Write Apple Notes",
      "type": "local",
      "access": "readwrite",
      "category": "communication",
      "command": "node",
      "args": ["/Users/nb/Desktop/Projects/github.com/CHITTYOS/chittymac/build/server.js"],
      "env": {
        "NEON_DATABASE_URL": "op://Connect Serv - Production/NEON Notion DB - ChittyChain /password"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "id": "imessage",
      "name": "Read and Send iMessages",
      "type": "local",
      "access": "readwrite",
      "category": "communication",
      "command": "/bin/sh",
      "args": ["-c", "source /Users/nb/.config/claude/mcp-servers/chitty-imessage/.env && exec node /Users/nb/.config/claude/mcp-servers/chitty-imessage/build/index.js"],
      "lazy": true,
      "enabled": true
    }
  ]
}
