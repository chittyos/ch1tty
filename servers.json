{
  "servers": [
    {
      "_comment": "── remote: HTTP endpoints (work everywhere) ──────────────────"
    },
    {
      "_comment": "ChittyAgent-Tasks — enable once /mcp endpoint ships on tasks.chitty.cc (see chittyentity/workers/chittyagent-tasks). Currently exposes REST only."
    },
    {
      "id": "tasks",
      "name": "ChittyAgent Tasks",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://tasks.chitty.cc/mcp",
      "authTokenKey": "chittytasks",
      "lazy": true,
      "enabled": false
    },
    {
      "id": "chittyos",
      "name": "ChittyOS Ecosystem",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://mcp-portal.chitty.cc/mcp",
      "envHeaders": {
        "CF-Access-Client-Id": "CHITTY_CF_ACCESS_CLIENT_ID",
        "CF-Access-Client-Secret": "CHITTY_CF_ACCESS_CLIENT_SECRET"
      },
      "authTokenKey": "chittymcp",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "cloudflare",
      "name": "Cloudflare Platform",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://mcp.cloudflare.com/mcp",
      "authTokenKey": "cloudflare-mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "evidence",
      "name": "Evidence Search",
      "type": "remote",
      "access": "read",
      "category": "search",
      "endpoint": "https://autorag.mcp.cloudflare.com/mcp",
      "authTokenKey": "chittyevidence-search",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "browser-rendering",
      "name": "Cloudflare Browser Rendering",
      "type": "remote",
      "access": "read",
      "category": "desktop",
      "endpoint": "https://browser.mcp.cloudflare.com/mcp",
      "authTokenKey": "cloudflare-browser-rendering",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "cowork",
      "name": "Co-Work VM Bridge",
      "type": "remote",
      "access": "readwrite",
      "category": "desktop",
      "endpoint": "http://127.0.0.1:8850/mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "_comment": "── local: portable stdio servers (npx/uvx, no hardcoded paths) ─"
    },
    {
      "id": "notion",
      "name": "Notion",
      "type": "local",
      "access": "readwrite",
      "category": "documents",
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "op://ChittyOS-Integrations/notion/api_token"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "id": "stripe",
      "name": "Stripe Billing",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "npx",
      "args": [
        "-y",
        "@stripe/mcp"
      ],
      "env": {
        "STRIPE_SECRET_KEY": "op://ChittyOS-Integrations/stripe/secret_key"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "_comment": "github: official GitHub hosted MCP server (replaces deprecated @modelcontextprotocol/server-github). Auth via GITHUB_MCP_AUTHORIZATION env var holding 'Bearer <PAT>'; populate from op://ChittyOS-Integrations/github/personal_access_token (e.g. export GITHUB_MCP_AUTHORIZATION=\"Bearer $(op read op://ChittyOS-Integrations/github/personal_access_token)\"). The chitty-mcp-token broker has no 'github' key, so authTokenKey is not used here."
    },
    {
      "id": "github",
      "name": "GitHub API",
      "type": "remote",
      "access": "readwrite",
      "category": "code",
      "endpoint": "https://api.githubcopilot.com/mcp/",
      "envHeaders": {
        "Authorization": "GITHUB_MCP_AUTHORIZATION"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "id": "neon",
      "name": "Neon Database",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "npx",
      "args": [
        "-y",
        "@neondatabase/mcp-server-neon",
        "start"
      ],
      "env": {
        "NEON_API_KEY": "op://ChittyOS-Integrations/neon/api_key"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "id": "context7",
      "name": "Library Docs",
      "type": "local",
      "access": "read",
      "category": "documents",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "thinking",
      "name": "Sequential Thinking",
      "type": "local",
      "access": "read",
      "category": "reasoning",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "fs",
      "name": "Filesystem",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/projects",
        "~/Documents"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "playwright",
      "name": "Browser Automation",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "_comment": "── macOS: run on homelab, TODO: proxy via ChittyConnect ───────"
    },
    {
      "id": "chittymac",
      "name": "Apple Notes (macOS homelab)",
      "type": "local",
      "access": "readwrite",
      "category": "communication",
      "command": "node",
      "args": [
        "~/Desktop/Projects/github.com/CHITTYOS/chittymac/build/server.js"
      ],
      "env": {
        "NEON_DATABASE_URL": "op://Connect Serv - Production/NEON Notion DB - ChittyChain /password"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "id": "imessage",
      "name": "iMessage (macOS homelab)",
      "type": "local",
      "access": "readwrite",
      "category": "communication",
      "command": "node",
      "args": [
        "~/.config/claude/mcp-servers/chitty-imessage/build/index.js"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "_comment": "── disabled: need local install or not yet ported ────────────"
    },
    {
      "id": "serena",
      "name": "Source Code Analysis",
      "type": "local",
      "access": "readwrite",
      "category": "code",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "quality",
      "name": "Quality Metrics",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "node",
      "args": [
        "~/.config/claude/mcp-servers/chitty-quality/build/index.js"
      ],
      "env": {
        "NEON_DATABASE_URL": "op://Private/Neon/database_url"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "id": "desktop",
      "name": "Desktop Commander (macOS)",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": [
        "-y",
        "@wonderwhy-er/desktop-commander@latest"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "chrome",
      "name": "Chrome Control (macOS)",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "node",
      "args": [
        "~/Library/Application Support/Claude/Claude Extensions/ant.dir.ant.anthropic.chrome-control/server/index.js"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "pdf",
      "name": "PDF Filler (macOS)",
      "type": "local",
      "access": "write",
      "category": "documents",
      "command": "node",
      "args": [
        "~/Library/Application Support/Claude/Claude Extensions/ant.dir.gh.silverstein.pdf-filler-simple/server/index.js"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "orchestrator",
      "name": "ChittyAgent Orchestrator",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://orchestrator.agent.chitty.cc/mcp",
      "authTokenKey": "chittymcp",
      "lazy": false,
      "enabled": true
    }
  ]
}
