{
  "servers": [
    {
      "_comment": "── remote: HTTP endpoints (work everywhere) ──────────────────"
    },
    {
      "_comment": "ChittyAgent-Tasks — apps/tasks-mcp local MCP surface wrapping the tasks.chitty.cc REST API. Enable once CHITTY_TASKS_TOKEN is set. Build: cd apps/tasks-mcp && npm ci && npm run build"
    },
    {
      "id": "tasks",
      "name": "ChittyAgent Tasks",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "node",
      "args": [
        "./apps/tasks-mcp/dist/index.js"
      ],
      "env": {
        "CHITTY_TASKS_URL": "https://tasks.chitty.cc",
        "CHITTY_TASKS_TOKEN": "op://ChittyOS-Integrations/chittytasks/token"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "_comment": "ChittyLedger — apps/ledger-mcp local MCP surface wrapping the ledger.chitty.cc append-only ledger REST API. Enable once CHITTY_LEDGER_TOKEN is set. Build: cd apps/ledger-mcp && npm ci && npm run build"
    },
    {
      "id": "ledger",
      "name": "ChittyLedger",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "node",
      "args": [
        "./apps/ledger-mcp/dist/index.js"
      ],
      "env": {
        "CHITTY_LEDGER_URL": "https://ledger.chitty.cc",
        "CHITTY_LEDGER_TOKEN": "op://ChittyOS-Integrations/chittyledger/token"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "_comment": "ChittyOS Session Coordinator — apps/session-coordinator-mcp local MCP surface wrapping the session.chitty.cc REST API. Enable once CHITTY_SESSION_TOKEN is set. Build: cd apps/session-coordinator-mcp && npm ci && npm run build"
    },
    {
      "id": "session",
      "name": "ChittyOS Session Coordinator",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "node",
      "args": [
        "./apps/session-coordinator-mcp/dist/index.js"
      ],
      "env": {
        "CHITTY_SESSION_URL": "https://session.chitty.cc",
        "CHITTY_SESSION_TOKEN": "op://ChittyOS-Integrations/chittysession/token"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "_comment": "ChittyEvidence — apps/evidence-mcp local MCP surface wrapping the evidence.chitty.cc document ingest + canonical URI REST API. Enable once CHITTY_EVIDENCE_TOKEN is set. Build: cd apps/evidence-mcp && npm ci && npm run build"
    },
    {
      "id": "chittyevidence",
      "name": "ChittyEvidence",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "node",
      "args": [
        "./apps/evidence-mcp/dist/index.js"
      ],
      "env": {
        "CHITTY_EVIDENCE_URL": "https://evidence.chitty.cc",
        "CHITTY_EVIDENCE_TOKEN": "op://ChittyOS-Integrations/chittyevidence/token"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "id": "chittyos",
      "name": "ChittyOS Ecosystem",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://mcp.chitty.cc/mcp",
      "envHeaders": {
        "CF-Access-Client-Id": "CHITTY_CF_ACCESS_CLIENT_ID",
        "CF-Access-Client-Secret": "CHITTY_CF_ACCESS_CLIENT_SECRET"
      },
      "authTokenKey": "chittymcp",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "cloudflare",
      "name": "Cloudflare Platform",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://mcp.cloudflare.com/mcp",
      "authTokenKey": "cloudflare-mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "_comment": "Cloudflare Workers Builds MCP — official CF MCP for managing Workers Builds (CI deploy config, build/deploy commands, build runs). Used to programmatically fix chittyentity dashboard config drift on chittyagent-{quo,ch1tty,ui} (build_command + --env production on deploy_command, see chittyentity#336). OAuth via DCR; access token brokered as 'cloudflare-builds-mcp'."
    },
    {
      "id": "cloudflare-builds",
      "name": "Cloudflare Workers Builds",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://builds.mcp.cloudflare.com/mcp",
      "authTokenKey": "cloudflare-builds-mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "evidence",
      "name": "Evidence Search",
      "type": "remote",
      "access": "read",
      "category": "search",
      "endpoint": "https://autorag.mcp.cloudflare.com/mcp",
      "authTokenKey": "chittyevidence-search",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "browser-rendering",
      "name": "Cloudflare Browser Rendering",
      "type": "remote",
      "access": "read",
      "category": "desktop",
      "endpoint": "https://browser.mcp.cloudflare.com/mcp",
      "authTokenKey": "cloudflare-browser-rendering",
      "lazy": true,
      "enabled": true
    },
    {
      "id": "cowork",
      "name": "Co-Work VM Bridge",
      "type": "remote",
      "access": "readwrite",
      "category": "desktop",
      "endpoint": "http://127.0.0.1:8850/mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "_comment": "github: official GitHub hosted MCP server (replaces deprecated @modelcontextprotocol/server-github). Auth via GITHUB_MCP_AUTHORIZATION env var holding 'Bearer <PAT>'; populate from op://ChittyOS-Integrations/github/personal_access_token (e.g. export GITHUB_MCP_AUTHORIZATION=\"Bearer $(op read op://ChittyOS-Integrations/github/personal_access_token)\"). The chitty-mcp-token broker has no 'github' key, so authTokenKey is not used here."
    },
    {
      "id": "github",
      "name": "GitHub API",
      "type": "remote",
      "access": "readwrite",
      "category": "code",
      "endpoint": "https://api.githubcopilot.com/mcp/",
      "envHeaders": {
        "Authorization": "GITHUB_MCP_AUTHORIZATION"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "id": "linear",
      "name": "Linear",
      "type": "remote",
      "access": "readwrite",
      "category": "code",
      "endpoint": "https://mcp.linear.app/mcp",
      "authTokenKey": "linear-mcp",
      "lazy": true,
      "enabled": true
    },
    {
      "_comment": "── local: portable stdio servers (npx/uvx, no hardcoded paths) ─"
    },
    {
      "id": "notion",
      "name": "Notion",
      "type": "local",
      "access": "readwrite",
      "category": "documents",
      "command": "/home/ubuntu/.local/bin/notion-mcp-wrapper.sh",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {},
      "lazy": true,
      "enabled": true
    },
    {
      "id": "stripe",
      "name": "Stripe Billing",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "npx",
      "args": [
        "-y",
        "@stripe/mcp"
      ],
      "env": {
        "STRIPE_SECRET_KEY": "op://ChittyOS-Integrations/stripe/secret_key"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "id": "neon",
      "name": "Neon Database",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "npx",
      "args": [
        "-y",
        "@neondatabase/mcp-server-neon",
        "start"
      ],
      "env": {
        "NEON_API_KEY": "op://ChittyOS-Integrations/neon/api_key"
      },
      "lazy": true,
      "enabled": true
    },
    {
      "id": "context7",
      "name": "Library Docs",
      "type": "local",
      "access": "read",
      "category": "documents",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "thinking",
      "name": "Sequential Thinking",
      "type": "local",
      "access": "read",
      "category": "reasoning",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "fs",
      "name": "Filesystem",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/projects",
        "~/Documents"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "id": "playwright",
      "name": "Browser Automation",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "lazy": true,
      "enabled": true
    },
    {
      "_comment": "── macOS: run on homelab, TODO: proxy via ChittyConnect ───────"
    },
    {
      "id": "chittymac",
      "name": "Apple Notes (macOS homelab)",
      "type": "local",
      "access": "readwrite",
      "category": "communication",
      "command": "node",
      "args": [
        "~/Desktop/Projects/github.com/CHITTYOS/chittymac/build/server.js"
      ],
      "env": {
        "NEON_DATABASE_URL": "op://Connect Serv - Production/NEON Notion DB - ChittyChain /password"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "id": "imessage",
      "name": "iMessage (macOS homelab)",
      "type": "local",
      "access": "readwrite",
      "category": "communication",
      "command": "node",
      "args": [
        "~/.config/claude/mcp-servers/chitty-imessage/build/index.js"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "_comment": "── disabled: need local install or not yet ported ────────────"
    },
    {
      "id": "serena",
      "name": "Source Code Analysis",
      "type": "local",
      "access": "readwrite",
      "category": "code",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "quality",
      "name": "Quality Metrics",
      "type": "local",
      "access": "readwrite",
      "category": "ecosystem",
      "command": "node",
      "args": [
        "~/.config/claude/mcp-servers/chitty-quality/build/index.js"
      ],
      "env": {
        "NEON_DATABASE_URL": "op://Private/Neon/database_url"
      },
      "lazy": true,
      "enabled": false
    },
    {
      "id": "desktop",
      "name": "Desktop Commander (macOS)",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "npx",
      "args": [
        "-y",
        "@wonderwhy-er/desktop-commander@latest"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "chrome",
      "name": "Chrome Control (macOS)",
      "type": "local",
      "access": "readwrite",
      "category": "desktop",
      "command": "node",
      "args": [
        "~/Library/Application Support/Claude/Claude Extensions/ant.dir.ant.anthropic.chrome-control/server/index.js"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "pdf",
      "name": "PDF Filler (macOS)",
      "type": "local",
      "access": "write",
      "category": "documents",
      "command": "node",
      "args": [
        "~/Library/Application Support/Claude/Claude Extensions/ant.dir.gh.silverstein.pdf-filler-simple/server/index.js"
      ],
      "lazy": true,
      "enabled": false
    },
    {
      "id": "orchestrator",
      "name": "ChittyAgent Orchestrator",
      "type": "remote",
      "access": "readwrite",
      "category": "ecosystem",
      "endpoint": "https://orchestrator.chitty.cc/mcp",
      "authTokenKey": "chittymcp",
      "lazy": false,
      "enabled": true
    }
  ]
}
