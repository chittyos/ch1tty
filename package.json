{
  "name": "ch1tty",
  "version": "4.1.0",
  "description": "ChittyOS Universal MCP Gateway — one stdio server, all backends",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "sim": "CH1TTY_EMBED_ENABLED=false node --import tsx sim/run.ts",
    "test": "node --import tsx --test test/**/*.test.ts apps/*/test/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/**/*.test.ts apps/*/test/*.test.ts",
    "coverage": "c8 --all --include=src-stdio/**/*.ts --exclude=src-stdio/index.ts --exclude=src-stdio/types.ts --lines 99 --branches 95 --functions 100 --statements 99 node --import tsx --test test/**/*.test.ts apps/*/test/*.test.ts"
  },
  "dependencies": {
    "@chittyos/schema-client": "file:../../CHITTYFOUNDATION/chittyschema/clients/schema-client",
    "@cloudflare/codemode": "^0.4.3",
    "@cloudflare/workers-oauth-provider": "^0.8.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.17.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "wrangler": "^4.79.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "hono": ">=4.12.27",
    "sharp": ">=0.35.0"
  }
}
