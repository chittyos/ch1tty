{
  "name": "ch1tty",
  "version": "4.1.0",
  "description": "ChittyOS Universal MCP Gateway — one stdio server, all backends",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "sim": "CH1TTY_EMBED_ENABLED=false node --import tsx sim/run.ts",
    "test": "node --import tsx --test test/**/*.test.ts apps/*/test/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/**/*.test.ts apps/*/test/*.test.ts",
    "coverage": "c8 --all --include=src/**/*.ts --exclude=src/index.ts --exclude=src/types.ts --lines 99 --branches 95 --functions 100 --statements 99 node --import tsx --test test/**/*.test.ts apps/*/test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
